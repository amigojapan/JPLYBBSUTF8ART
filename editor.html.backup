<!DOCTYPE html>

<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Braille ASCII Editor PRO</title>

<style>
body {
  margin:0;
  background:#111;
  color:#eee;
  font-family:monospace;
  display:flex;
  flex-direction:column;
  align-items:center;
}

#toolbar {
  display:flex;
  flex-wrap:wrap;
  gap:5px;
  padding:10px;
}

.colorBtn {
  width:28px;height:28px;border:2px solid #444;
}
.colorBtn.active { border:2px solid #fff; }

.toolBtn {
  padding:5px;
  background:#222;
  border:1px solid #555;
  cursor:pointer;
}
.toolBtn.active { background:#555; }

canvas {
  touch-action:none;
  background:#000;
}

#output {
  width:95%;
  height:200px;
  background:#000;
  color:#0f0;
  margin-top:10px;
  padding:10px;
  overflow:auto;
  white-space:pre;
}
</style>

</head>

<body>

<div id="toolbar"></div>

<div id="tools">
  <button class="toolBtn" onclick="setTool('draw')">Draw</button>
  <button class="toolBtn" onclick="setTool('erase')">Erase</button>
  <button class="toolBtn" onclick="setTool('line')">Line</button>
  <button class="toolBtn" onclick="setTool('rect')">Rect</button>
</div>

<canvas id="canvas"></canvas>

<div>
  <button onclick="clearGrid()">Clear</button>
  <button onclick="exportBraille()">Export</button>
  <button onclick="copyOutput()">Copy</button>
  <button onclick="saveLocal()">Save</button>
  <button onclick="loadLocal()">Load</button>
  <button onclick="downloadJSON()">Download</button>
  <input type="file" onchange="uploadJSON(event)">
  <input type="file" accept="image/*" onchange="importImage(event)">
</div>

<pre id="output"></pre>

<script>
// ===== PALETTE =====
function getColor(n) {
  const table = {
    0:"#000000",1:"#ffffff",2:"#808080",3:"#659BDF",
    4:"#a9a9a9",7:"#c0c0c0",8:"#dda0dd",9:"#ee82ee",
    10:"#ff0000",11:"#ffa500",12:"#ffff00",13:"#008000",
    14:"#0000ff",15:"#4b0082",16:"#800080"
  };
  return table.hasOwnProperty(n) ? table[n] : "#000";
}

// ===== CONFIG =====
const W=80,H=40,PIX=10;
let currentColor=10;
let tool="draw";

// ===== GRID =====
let grid=Array.from({length:H},()=>Array.from({length:W},()=>({on:0,color:0})));

// ===== CANVAS =====
const canvas=document.getElementById("canvas");
canvas.width=W*PIX;
canvas.height=H*PIX;
const ctx=canvas.getContext("2d");

// ===== RENDER =====
function render(){
  for(let y=0;y<H;y++){
    for(let x=0;x<W;x++){
      let p=grid[y][x];
      ctx.fillStyle=p.on?getColor(p.color):"#000";
      ctx.fillRect(x*PIX,y*PIX,PIX,PIX);
    }
  }
}

// ===== TOOLS =====
function setTool(t){
  tool=t;
  document.querySelectorAll(".toolBtn").forEach(b=>b.classList.remove("active"));
  [...document.querySelectorAll(".toolBtn")].find(b=>b.textContent.toLowerCase()==t).classList.add("active");
}

// ===== INPUT =====
let drawing=false,startX=0,startY=0;

function getPos(e){
  const r=canvas.getBoundingClientRect();
  return {
    x:Math.floor((e.clientX-r.left)/PIX),
    y:Math.floor((e.clientY-r.top)/PIX)
  };
}

function applyPixel(x,y,erase=false){
  if(!grid[y]||!grid[y][x]) return;
  grid[y][x]=erase?{on:0,color:0}:{on:1,color:currentColor};
}

function drawLine(x0,y0,x1,y1){
  let dx=Math.abs(x1-x0),sx=x0<x1?1:-1;
  let dy=-Math.abs(y1-y0),sy=y0<y1?1:-1;
  let err=dx+dy;
  while(true){
    applyPixel(x0,y0);
    if(x0===x1&&y0===y1) break;
    let e2=2*err;
    if(e2>=dy){err+=dy;x0+=sx;}
    if(e2<=dx){err+=dx;y0+=sy;}
  }
}

function drawRect(x0,y0,x1,y1){
  for(let x=x0;x<=x1;x++){
    applyPixel(x,y0);
    applyPixel(x,y1);
  }
  for(let y=y0;y<=y1;y++){
    applyPixel(x0,y);
    applyPixel(x1,y);
  }
}

canvas.addEventListener("mousedown",e=>{
  drawing=true;
  let p=getPos(e);
  startX=p.x;startY=p.y;

  if(tool==="draw") applyPixel(p.x,p.y);
  if(tool==="erase") applyPixel(p.x,p.y,true);

  render();
});

canvas.addEventListener("mousemove",e=>{
  if(!drawing) return;
  let p=getPos(e);

  if(tool==="draw") applyPixel(p.x,p.y);
  if(tool==="erase") applyPixel(p.x,p.y,true);

  render();
});

window.addEventListener("mouseup",e=>{
  if(!drawing) return;
  drawing=false;

  let p=getPos(e);

  if(tool==="line") drawLine(startX,startY,p.x,p.y);
  if(tool==="rect") drawRect(startX,startY,p.x,p.y);

  render();
});

// TOUCH
canvas.addEventListener("touchstart",e=>{
  drawing=true;
  let p=getPos(e.touches[0]);
  startX=p.x;startY=p.y;
});
canvas.addEventListener("touchend",e=>{
  drawing=false;
});

// ===== PALETTE UI =====
const toolbar=document.getElementById("toolbar");
for(let i=0;i<=16;i++){
  let b=document.createElement("div");
  b.className="colorBtn";
  b.style.background=getColor(i);
  b.onclick=()=>{
    currentColor=i;
    document.querySelectorAll(".colorBtn").forEach(x=>x.classList.remove("active"));
    b.classList.add("active");
  };
  if(i===currentColor) b.classList.add("active");
  toolbar.appendChild(b);
}

// ===== BRAILLE =====
const dots=[[0,0,1],[0,1,2],[0,2,4],[1,0,8],[1,1,16],[1,2,32],[0,3,64],[1,3,128]];

function getFG(block){
  let c={};
  for(let p of block){ if(p.on)c[p.color]=(c[p.color]||0)+1;}
  let best=1,max=-1;
  for(let k in c){ if(c[k]>max){max=c[k];best=parseInt(k);} }
  return best;
}

function convert(){
  let out="",lf=null,lb=null;

  for(let y=0;y<H;y+=4){
    for(let x=0;x<W;x+=2){

      let block=[];
      for(let dy=0;dy<4;dy++){
        for(let dx=0;dx<2;dx++){
          let p=grid[y+dy]?.[x+dx];
          if(p) block.push(p);
        }
      }

      let fgc=getFG(block),bgc=0;

      let code=0;
      for(let d of dots){
        let p=grid[y+d[1]]?.[x+d[0]];
        if(p&&p.on&&p.color===fgc) code|=d[2];
      }

      let ch=String.fromCharCode(0x2800+code);

      if(fgc!==lf||bgc!==lb){
        out+=`[C${fgc},${bgc}]`;
        lf=fgc;lb=bgc;
      }

      out+=ch;
    }
    out+="\n";
  }
  return out;
}

// ===== ACTIONS =====
function exportBraille(){
  document.getElementById("output").textContent=convert();
}
function copyOutput(){
  navigator.clipboard.writeText(convert());
}
function clearGrid(){
  for(let y=0;y<H;y++)for(let x=0;x<W;x++)grid[y][x]={on:0,color:0};
  render();
}

// ===== SAVE/LOAD =====
function saveLocal(){
  localStorage.setItem("brailleArt",JSON.stringify(grid));
}
function loadLocal(){
  let d=localStorage.getItem("brailleArt");
  if(d) grid=JSON.parse(d);
  render();
}

function downloadJSON(){
  let blob=new Blob([JSON.stringify(grid)],{type:"application/json"});
  let a=document.createElement("a");
  a.href=URL.createObjectURL(blob);
  a.download="art.json";
  a.click();
}

function uploadJSON(e){
  let f=e.target.files[0];
  let r=new FileReader();
  r.onload=()=>{
    grid=JSON.parse(r.result);
    render();
  };
  r.readAsText(f);
}

// ===== IMAGE IMPORT =====
function importImage(e){
  let img=new Image();
  img.onload=()=>{
    let temp=document.createElement("canvas");
    temp.width=W;
    temp.height=H;
    let tctx=temp.getContext("2d");

    tctx.drawImage(img,0,0,W,H);
    let data=tctx.getImageData(0,0,W,H).data;

    for(let y=0;y<H;y++){
      for(let x=0;x<W;x++){
        let i=(y*W+x)*4;
        let r=data[i],g=data[i+1],b=data[i+2];

        let brightness=(r+g+b)/3;

        if(brightness>80){
          grid[y][x]={on:1,color:closestColor(r,g,b)};
        } else {
          grid[y][x]={on:0,color:0};
        }
      }
    }

    render();
  };
  img.src=URL.createObjectURL(e.target.files[0]);
}

function closestColor(r,g,b){
  let best=0,dist=1e9;
  for(let i=0;i<=16;i++){
    let hex=getColor(i);
    let rr=parseInt(hex.substr(1,2),16);
    let gg=parseInt(hex.substr(3,2),16);
    let bb=parseInt(hex.substr(5,2),16);

    let d=(r-rr)**2+(g-gg)**2+(b-bb)**2;
    if(d<dist){dist=d;best=i;}
  }
  return best;
}

// INIT
render();
</script>

</body>
</html>
